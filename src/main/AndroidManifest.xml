<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- v1.0.8 PHASE 30: removed redundant package/versionCode/versionName attributes
         and the <uses-sdk> element — AGP 8.x pulls these from build.gradle
         (namespace, versionCode, versionName, minSdk, targetSdk). Keeping them
         created two sources of truth and the package attribute is deprecated. -->

    <!-- Required permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- v1.2.3 round-18: removed ACCESS_NETWORK_STATE — zero usage anywhere in
         the codebase (no ConnectivityManager/NetworkCallback/navigator.onLine;
         WebView queries network state in its own process). Permission
         minimization. -->
    <!-- Keep screen on during gameplay -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- v18.4.5 FIX: VIBRATE permission required for haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Android 5-9: Storage permissions for settings export/import -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- v1.0.2 REDUNDANCY (audit): removed READ_MEDIA_IMAGES — the built-in file
         browser queries MediaStore.Files (not MediaStore.Images), which does not
         require READ_MEDIA_IMAGES on Android 13+. The SAF picker (the primary
         import/export path) needs no permissions at all. -->
    <!-- v18.4.0: Request foreground service for engine stability on HyperOS -->
    <!-- v1.0.8 PHASE 30: removed android:minSdkVersion — it is NOT a valid attribute
         on <uses-permission> (only maxSdkVersion is supported). The system no-ops
         these permissions on older API levels, so the attribute was misleading. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- v18.4.7: Android 14+ requires specifying foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Android 13+ (API 33): POST_NOTIFICATIONS required for foreground service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Declare native library requirement -->
    <!-- v18.5.0: portrait no longer required — app supports both orientations -->
    <uses-feature android:name="android.hardware.screen.portrait" android:required="false" />
    <uses-feature android:name="android.hardware.screen.landscape" android:required="false" />

    <!-- v1.2.3 round-13 (P1): Android 11+ (API 30) package visibility restrictions
         silently hide other apps' packages from PackageManager.getPackageInfo.
         Without this <queries> block, RootDetector.checkRootPackages returns false
         on every API 30+ device even when Magisk is installed — defeating signal #1
         of the root detection. Targeted <queries> is preferred over QUERY_ALL_PACKAGES
         (the latter is restricted by Google Play policy and triggers MobSF warnings).
         The package names mirror RootDetector.ROOT_PACKAGES exactly. -->
    <queries>
        <package android:name="com.topjohnwu.magisk" />
        <package android:name="eu.chainfire.supersu" />
        <package android:name="com.koushikdutta.superuser" />
        <package android:name="com.thirdparty.superuser" />
        <package android:name="com.kingouser.com" />
        <package android:name="com.kingroot.kingroot" />
        <package android:name="com.noshufou.android.su" />
        <package android:name="com.noshufou.android.su.elite" />
        <package android:name="com.yellowes.su" />
        <package android:name="com.koushikdutta.rommanager" />
        <package android:name="com.dimonvideo.luckypatcher" />
        <package android:name="com.chelpus.lackypatch" />
    </queries>

    <application
        android:name="com.Regalia.ChessApp"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.NoTitleBar"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:extractNativeLibs="true"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- v1.2.3 round-13 (P2): removed android:fullBackupContent and
             android:dataExtractionRules. When allowBackup="false" (the
             documented v1.0.4 design decision — engine config and PGN cache
             are considered private), both backup rule files are never
             consulted, so the references were dead config that misled readers
             into thinking selective backup was active. The two XML files
             (backup_rules.xml, data_extraction_rules.xml) are retained in
             res/xml/ for reference but no longer wired. To re-enable selective
             backup in the future, set allowBackup="true" and re-add both
             attributes pointing at the existing rule files. -->
        <!-- v1.2.1 round-10 (review-F P3): removed android:requestLegacyExternalStorage="true"
             — this attribute is ignored when targetSdk >= 30 (we use 35). The app
             uses SAF for all file I/O (no File API external-storage access), so the
             legacy storage mode was never actually consulted. Keeping it was dead
             configuration that misled readers into thinking we relied on legacy FS. -->

        <!-- v18.5.0 FIX: Changed from "portrait" to "unspecified" — the previous
             portrait lock prevented CSS @media (orientation:landscape) from ever
             triggering because the WebView viewport was always in portrait dimensions.
             Now the Activity can rotate, and CSS landscape rules work correctly.
             configChanges ensures we handle rotation without recreating the Activity. -->
        <activity
            android:name="com.Regalia.MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:configChanges="keyboardHidden|orientation|screenSize|smallestScreenSize|density|uiMode"
            android:windowSoftInputMode="adjustPan"
            android:hardwareAccelerated="true"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- v18.4.7: Foreground service to keep the chess engine process alive
             on Android 14/15 (Xiaomi HyperOS 3). Without this, the OS aggressively
             kills the engine subprocess when the app goes to background.
             v1.2.1 round-9: Added the required <property> child element for
             FOREGROUND_SERVICE_TYPE_SPECIAL_USE. Per Android 14 docs, apps
             targeting API 34+ using FOREGROUND_SERVICE_TYPE_SPECIAL_USE MUST
             declare the subtype property via
             android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE, otherwise
             startForeground(..., FOREGROUND_SERVICE_TYPE_SPECIAL_USE) can
             throw ForegroundServiceTypeNotAllowed on Android 14+ devices. -->
        <service
            android:name="com.Regalia.EngineService"
            android:foregroundServiceType="specialUse"
            android:exported="false"
            android:stopWithTask="true">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="chess_engine_analysis" />
        </service>

        <!-- v1.0.2 NEW FEATURE: StatsActivity — fullscreen WebView for the 📊统计
             statistics page. Displays PGN with rich formatting + computed statistics.
             PGN parsing in stats.html is derived from DroidFish (GPL v3). -->
        <activity
            android:name="com.Regalia.StatsActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:configChanges="keyboardHidden|orientation|screenSize|smallestScreenSize|density|uiMode"
            android:windowSoftInputMode="adjustPan"
            android:hardwareAccelerated="true"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:windowLayoutInDisplayCutoutMode="shortEdges" />

    </application>

</manifest>
